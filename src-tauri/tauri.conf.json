{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oura-stream",
  "version": "2.0.2",
  "identifier": "com.kim.oura-stream",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "oura-stream",
        "width": 1200,
        "height": 700,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "maximized": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/sneppec98-wq/oura-stream/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2QjREMTIzRjUwRERGRUEKUldUcTN3MzFJOUcwaHFHMWdqaHEzOGxaUEw5QmpSemt6MTJlcFNHTUxRelljclpyUEtlK05wRzgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}